"""
training/dataset.py
===================
Construction des fenêtres glissantes, normalisation et DataLoaders PyTorch.

Responsabilités :
    - Découper les features en train / val / test (70 / 15 / 15 %)
    - Normaliser chaque feature par son écart-type propre (calculé sur le train)
    - Construire les fenêtres glissantes (X, y)
    - Retourner les DataLoaders prêts à l'emploi
"""

import numpy as np
import torch
from torch.utils.data import TensorDataset, DataLoader


# ──────────────────────────────────────────────────────────────
# Fenêtre glissante
# ──────────────────────────────────────────────────────────────

def make_windows(
    serie: np.ndarray,
    window: int,
    seuil: float = 15.0,
) -> tuple[np.ndarray, np.ndarray]:
    """
    Découpe une série de features en fenêtres glissantes (X, y).

    Paramètres
    ----------
    serie  : tableau (N, F) de features normalisées
    window : nombre de pas de temps par fenêtre
    seuil  : valeur absolue maximale tolérée sur le log-return (feature 0)
             — filtre les outliers extrêmes

    Retourne
    --------
    X : tableau (M, window, F)
    y : tableau (M,)  — log-return à prédire (feature 0 au pas t+window)
    """
    x_list, y_list = [], []

    for i in range(len(serie) - window):
        fenetre = serie[i : i + window]
        cible   = serie[i + window, 0]

        # Filtrage des outliers sur le log-return
        if np.any(np.abs(fenetre[:, 0]) > seuil) or np.abs(cible) > seuil:
            continue

        x_list.append(fenetre)
        y_list.append(cible)

    return np.array(x_list), np.array(y_list)


# ──────────────────────────────────────────────────────────────
# Normalisation
# ──────────────────────────────────────────────────────────────

def normalize(
    train: np.ndarray,
    *others: np.ndarray,
) -> tuple[np.ndarray, ...]:
    """
    Normalise par l'écart-type du train uniquement (pas de soustraction de mu).
    Les log-diffs sont naturellement centrés autour de 0 par construction.

    Paramètres
    ----------
    train  : tableau (N_train, F) servant à calculer sigma
    others : tableaux supplémentaires (val, test…) à normaliser avec le même sigma

    Retourne
    --------
    Tuple (train_norm, *others_norm, sigma)
    sigma est retourné pour pouvoir dénormaliser plus tard si besoin.
    """
    sigma = np.std(train, axis=0)
    sigma = np.where(sigma == 0, 1.0, sigma)   # évite la division par zéro

    def _safe_normalize(arr: np.ndarray) -> np.ndarray:
        result = arr / sigma
        if not np.isfinite(result).all():
            result = np.nan_to_num(result, nan=0.0, posinf=0.0, neginf=0.0)
        return result

    normalized = tuple(_safe_normalize(a) for a in (train, *others))
    return (*normalized, sigma)


# ──────────────────────────────────────────────────────────────
# Construction des DataLoaders
# ──────────────────────────────────────────────────────────────

def build_loaders(
    x_train: np.ndarray,
    y_train: np.ndarray,
    x_val: np.ndarray,
    y_val: np.ndarray,
    x_test: np.ndarray,
    y_test: np.ndarray,
    batch_size: int = 50,
) -> tuple[DataLoader, DataLoader, DataLoader]:
    """
    Convertit les tableaux numpy en TensorDatasets et retourne les DataLoaders.

    Paramètres
    ----------
    x_train, y_train : données d'entraînement
    x_val,   y_val   : données de validation
    x_test,  y_test  : données de test
    batch_size       : taille des mini-batchs (défaut 50)

    Retourne
    --------
    loader_train, loader_val, loader_test
    """
    def _to_tensor(arr: np.ndarray) -> torch.Tensor:
        return torch.tensor(arr.astype(np.float32))

    def _make_loader(x, y, shuffle: bool) -> DataLoader:
        dataset = TensorDataset(_to_tensor(x), _to_tensor(y))
        return DataLoader(dataset, batch_size=batch_size, shuffle=shuffle)

    # Vérification des tenseurs avant de créer les loaders
    x_tr_t = _to_tensor(x_train)
    y_tr_t = _to_tensor(y_train)
    assert torch.isfinite(x_tr_t).all(), "NaN/Inf détecté dans x_train !"
    assert torch.isfinite(y_tr_t).all(), "NaN/Inf détecté dans y_train !"

    loader_train = DataLoader(
        TensorDataset(x_tr_t, y_tr_t), batch_size=batch_size, shuffle=True
    )
    loader_val  = _make_loader(x_val,  y_val,  shuffle=False)
    loader_test = _make_loader(x_test, y_test, shuffle=False)

    return loader_train, loader_val, loader_test
